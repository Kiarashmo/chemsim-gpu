# macOS
.DS_Store

# Build artifacts
build/
*.o
*.obj

# Editor / OS cruft
.vscode/
.idea/

# Local docs (proposal, slides)
docs/

# Poster: keep sources + built PDF/PNG, drop LaTeX build artifacts
poster/*.aux
poster/*.log
poster/*.out
poster/*.synctex.gz
poster/qa/

# Large or reproducible data (regenerate with preprocessing/)
data/*
!data/example.smi

# Raw profiler traces (the plots in results/ tell the story)
results/*.nsys-rep
results/*.sqlite
*.ncu-rep

# Python caches
__pycache__/
*.pyc
